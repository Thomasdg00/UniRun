<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UniRun" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/kinetic_primary_container</item>
        <item name="colorPrimaryVariant">@color/kinetic_primary_dim</item>
        <item name="colorOnPrimary">@color/kinetic_on_primary_fixed</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="android:windowBackground">@color/surface_background</item>
        <item name="android:colorBackground">@color/surface_background</item>
        <item name="android:statusBarColor">@color/kinetic_background</item>
        <item name="android:navigationBarColor">@color/kinetic_background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="ShapeAppearance.Kinetic.Button" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="KineticButtonPrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/kinetic_primary_container</item>
        <item name="android:textColor">@color/kinetic_on_primary_fixed</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Kinetic.Button</item>
        <item name="android:fontFamily">@font/font_headline</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="KineticButtonSurface" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/kinetic_surface_container_high</item>
        <item name="android:textColor">@color/kinetic_on_surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Kinetic.Button</item>
        <item name="android:fontFamily">@font/font_label</item>
        <item name="rippleColor">@color/kinetic_outline_variant</item>
    </style>
    <style name="Theme.UniRun" parent="Base.Theme.UniRun" />
</resources>

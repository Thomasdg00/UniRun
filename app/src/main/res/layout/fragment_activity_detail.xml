<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: icona + data + tipo sport -->
        <LinearLayout
            android:id="@+id/llDetailHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvDetailSportIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:textSize="40sp"
                android:gravity="center"
                android:text="🏃" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvDetailSport"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Corsa"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />

                <TextView
                    android:id="@+id/tvDetailDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/01/2026"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Stats grid 2x3 -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distanza"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetailDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 km"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Durata"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetailDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Passo Medio"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetailPace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00 min/km"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Velocità Media"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetailSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 km/h"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calorie"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />
                <TextView
                    android:id="@+id/tvDetailCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 kcal"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="?android:attr/textColorPrimary" />
            </LinearLayout>

        </GridLayout>

        <!-- Mappa statica percorso -->
        <com.mapbox.maps.MapView
            android:id="@+id/mapViewDetail"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="24dp" />

        <!-- Grafico velocità -->
        <TextView
            android:id="@+id/tvChartTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Velocità nel tempo"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="8dp" />
            
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/chartSpeed"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="32dp" />

        <!-- Pulsante elimina -->
        <Button
            android:id="@+id/btnDeleteActivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"
            android:text="ELIMINA ATTIVITÀ" />

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/surface_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvGearName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nome Attrezzatura"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnDeleteGear" />

        <TextView
            android:id="@+id/tvGearType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👟 Scarpe"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvGearName"
            android:layout_marginTop="4dp" />

        <ProgressBar
            android:id="@+id/progressGearWear"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvGearType"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvGearKm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 500 km"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressGearWear"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvGearAlert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Usura elevata!"
            android:textColor="#F44336"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressGearWear"
            android:layout_marginTop="4dp" />

        <ImageButton
            android:id="@+id/btnDeleteGear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/tvWaterTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💧 Acqua"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvWaterGoal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Obiettivo: 2000 ml"
        android:textSize="18sp"
        android:layout_marginBottom="32dp" />

    <ProgressBar
        android:id="@+id/progressWater"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:max="2000"
        android:progress="0"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvWaterPercentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textSize="16sp"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvWaterConsumed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 ml"
        android:textSize="48sp"
        android:textStyle="bold"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btnRemoveWater"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-250 ml"
            android:backgroundTint="#9E9E9E"
            android:textColor="@android:color/white"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btnAddWater"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+250 ml"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white" />

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kinetic_background"
    tools:context=".ui.auth.AuthFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Brand Section -->
        <TextView
            android:id="@+id/tvBrand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KINETIC"
            android:textSize="48sp"
            android:textStyle="bold|italic"
            android:textColor="@color/kinetic_primary"
            android:letterSpacing="-0.05"
            android:fontFamily="@font/font_headline"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <!-- Brand Divider Line -->
        <View
            android:id="@+id/brandDivider"
            android:layout_width="48dp"
            android:layout_height="4dp"
            android:background="@color/kinetic_secondary"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp" />

        <!-- Headline -->
        <TextView
            android:id="@+id/tvHeadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/kinetic_on_surface"
            android:fontFamily="@font/font_headline"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENTER YOUR CREDENTIALS TO CONTINUE PERFORMANCE TRACKING"
            android:textSize="10sp"
            android:textColor="@color/kinetic_on_surface_variant"
            android:letterSpacing="0.15"
            android:fontFamily="@font/font_label"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp" />

        <!-- Email Input Card -->
        <LinearLayout
            android:id="@+id/emailCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_field"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Email Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textSize="9sp"
                android:textColor="@color/kinetic_primary_container"
                android:alpha="0.8"
                android:letterSpacing="0.15"
                android:fontFamily="@font/font_label"
                android:layout_marginBottom="8dp" />

            <!-- Email Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✉"
                    android:textSize="18sp"
                    android:textColor="@color/kinetic_outline"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="athlete@kinetic.io"
                    android:textColorHint="@color/kinetic_outline"
                    android:textColor="@color/kinetic_on_surface"
                    android:inputType="textEmailAddress"
                    android:fontFamily="@font/font_body"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Password Input Card -->
        <LinearLayout
            android:id="@+id/passwordCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_input_field"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <!-- Password Label Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PASSWORD"
                    android:textSize="9sp"
                    android:textColor="@color/kinetic_primary_container"
                    android:alpha="0.8"
                    android:letterSpacing="0.15"
                    android:fontFamily="@font/font_label" />

                <TextView
                    android:id="@+id/btnForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot password?"
                    android:textSize="9sp"
                    android:textColor="@color/kinetic_secondary"
                    android:fontFamily="@font/font_label"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Password Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="18sp"
                    android:textColor="@color/kinetic_outline"
                    android:layout_marginEnd="12dp" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="••••••••"
                    android:textColorHint="@color/kinetic_outline"
                    android:textColor="@color/kinetic_on_surface"
                    android:inputType="textPassword"
                    android:fontFamily="@font/font_body"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="Toggle password visibility"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_view" />
            </LinearLayout>
        </LinearLayout>

        <!-- LOGIN Button -->
        <Button
            android:id="@+id/btnLogin"
            style="@style/KineticButtonPrimary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="LOGIN"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp" />

        <!-- Divider with Label -->
        <LinearLayout
            android:id="@+id/dividerWithLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/kinetic_outline_variant"
                android:alpha="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOCIAL VELOCITY"
                android:textSize="8sp"
                android:letterSpacing="0.2"
                android:textColor="@color/kinetic_outline"
                android:fontFamily="@font/font_label"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/kinetic_outline_variant"
                android:alpha="0.2" />
        </LinearLayout>

        <!-- Google Sign-In Button -->
        <Button
            android:id="@+id/btnGoogleSignIn"
            style="@style/KineticButtonSurface"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="CONTINUA CON GOOGLE"
            android:textSize="14sp"
            android:drawableStart="@drawable/ic_google"
            android:drawablePadding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Footer Link -->
        <LinearLayout
            android:id="@+id/footerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? "
                android:textColor="@color/kinetic_on_surface"
                android:textSize="13sp"
                android:fontFamily="@font/font_body" />

            <TextView
                android:id="@+id/tvGoToRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Up"
                android:textColor="@color/kinetic_secondary"
                android:textStyle="bold"
                android:textSize="13sp"
                android:fontFamily="@font/font_body"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressAuth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp" />

        <!-- Error Message -->
        <TextView
            android:id="@+id/tvAuthError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/kinetic_error"
            android:background="@drawable/bg_error_message"
            android:padding="12dp"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/font_body"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>
